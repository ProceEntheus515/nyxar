# Entorno de NYXAR
REDIS_URL=redis://redis:6379/0  # URL para el bus de eventos y caché

# --- MongoDB (S05): autenticación obligatoria; usuarios creados en data/mongo-security-init.js ---
# Root solo para arranque/init (no uses en servicios en runtime).
MONGO_INITDB_ROOT_USERNAME=nyxar_root
MONGO_INITDB_ROOT_PASSWORD=cambiar_root_seguro
# Claves para nyxar_reader (read), nyxar_writer (readWrite), nyxar_admin (dbAdmin+readWrite en nyxar)
MONGO_READER_PASSWORD=cambiar_reader_seguro
MONGO_WRITER_PASSWORD=cambiar_writer_seguro
MONGO_ADMIN_PASSWORD=cambiar_admin_seguro
# Servicios del pipeline y API (readWrite). authSource=nyxar porque el usuario vive en la BD nyxar.
# Alias de red: mongo y mongodb apuntan al mismo contenedor (docker-compose.yml).
MONGODB_URL=mongodb://nyxar_writer:cambiar_writer_seguro@mongo:27017/nyxar?authSource=nyxar
# Producción con docker-compose.prod.yml (TLS): coloca data/ssl/nyxar-mongo.pem (clave+cert en un solo archivo).
# Generar PEM en Windows: .\scripts\gen_mongo_tls_pem.ps1 (OpenSSL en PATH; Git for Windows). -Force sobrescribe sin prompt.
# Manual (OpenSSL): openssl req -x509 -newkey rsa:4096 -days 365 -nodes -keyout key.pem -out cert.pem -subj "/CN=nyxar-mongodb/O=NYXAR" && type key.pem cert.pem > data\ssl\nyxar-mongo.pem
# Sustituir contraseña en la URL; tls=true obligatorio. tlsAllowInvalidCertificates solo en lab con cert autofirmado.
# MONGODB_URL=mongodb://nyxar_writer:CONTRASENA@mongo:27017/nyxar?authSource=nyxar&tls=true&tlsAllowInvalidCertificates=true
ANTHROPIC_API_KEY=your_anthropic_api_key_here  # Clave para Claude 3.5 Sonnet
# Modelo para threat_hunting (HypothesisEngine); por defecto claude-sonnet-4-20250514
THREAT_HUNTING_MODEL=
# Ventana temporal (horas) que Claude usa en $match al construir pipelines de hunting
HUNTING_QUERY_LOOKBACK_HOURS=24
ABUSEIPDB_KEY=your_abuseipdb_key_here  # Clave para enrichment de IP
VIRUSTOTAL_KEY=your_virustotal_key_here  # Clave para enrichment de URLs/Hashes
OTX_KEY=your_otx_key_here  # Clave para AlienVault OTX
LAB_MODE=true  # Si es true, usa el simulador en lugar de recolectores reales
LOG_LEVEL=INFO  # Nivel de logs: DEBUG, INFO, WARNING, ERROR

# --- observability (Prometheus /metrics + /health) ---
# Puerto HTTP del servicio (mapear igual en docker-compose si cambia)
OBSERVABILITY_PORT=9090
# Segundos entre pasadas del PipelineCollector (streams, heartbeats, agregados)
OBSERVABILITY_COLLECT_INTERVAL_S=30

# --- API: detalle de salud (GET /health/detail). Cabecera X-Nyxar-Health-Key ---
HEALTH_DETAIL_API_KEY=
# Dashboard (Vite): misma clave para bootstrap HTTP opcional + VITE_API_URL si la API no es localhost:8000
# VITE_HEALTH_DETAIL_KEY=
# VITE_API_URL=http://localhost:8000

# --- API: autenticación JWT + API keys (S01) ---
# Secreto HS256; mínimo 32 caracteres (p. ej. openssl rand -hex 32)
NYXAR_JWT_SECRET=
# Primer arranque sin admins en Mongo: crea este usuario (password hasheado, no se loguea)
NYXAR_ADMIN_USER=
NYXAR_ADMIN_PASS=

# --- API: CORS estricto y entorno (S02 hardening) ---
# Orígenes permitidos (CSV exacto). En producción no uses *.
NYXAR_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# development | production (bloquea CORS * en production)
NYXAR_ENV=development

# Versión expuesta en GET /api/v1/identity (system.version)
NYXAR_VERSION=1.0.0
# Primera marca de arranque (ISO UTC); si vacío, se persiste en .nyxar_state al iniciar la API
NYXAR_START_TIME=

# --- misp_connector ---
MISP_URL=https://misp.tu-instancia.com
MISP_API_KEY=tu_api_key_aqui
MISP_VERIFY_SSL=true
MISP_CONTRIBUTE=false
MISP_ORG_NAME=NYXAR
MISP_TLP=tlp:white
MISP_DISTRIBUTION=1
MISP_ALLOW_DISTRIBUTION_ALL=false
MISP_CONTRIBUTOR_POLL_S=60

# --- Active Directory / LDAP (ad_connector) ---
AD_SERVER=
AD_PORT=389
AD_USE_SSL=false
AD_DOMAIN=empresa.local
AD_BASE_DN=DC=empresa,DC=local
AD_USER=
AD_PASSWORD=
AD_SYNC_INTERVAL=300
# CSV de subcadenas (case-insensitive) en nombres de grupo AD para marcar privilegio alto
AD_PRIVILEGED_GROUP_PATTERNS=admin

# --- Wazuh: logons persistidos para mapa ip->usuario (rule.id del manager; vacio = solo fallback identities) ---
WAZUH_LOGON_RULE_IDS=
# CSV de rule.id para logoff (invalida caché identity:session). Si vacío, se usa texto 4634 en descripción.
WAZUH_LOGOFF_RULE_IDS=
# TTL en segundos para documentos en coleccion wazuh_logons (Mongo)
WAZUH_LOGONS_TTL_SECONDS=604800

# --- auto_response (motor SOAR) ---
AUTO_RESPONSE_ENABLED=false
AUTO_RESPONSE_POLL_S=45
AUTO_RESPONSE_CRITICO=false
AUTO_RESPONSE_USE_REDIS=true
AUTO_RESPONSE_LOOKBACK_DAYS=7
# Aprobaciones: timeout en horas para propuestas pendientes (estado expirado)
APPROVAL_TIMEOUT=24
# Si true, la API ejecuta playbooks al aprobar ademas de publicar approvals:ready
APPROVAL_SYNC_EXECUTE=true
# Segundos entre pasadas de auto_expire (API y motor auto_response)
APPROVAL_EXPIRE_POLL_S=900
# Redis: canal approvals:ready dispara execute_approved en el worker
FIREWALL_API_URL=
# Token opcional Bearer para la API del firewall
FIREWALL_API_TOKEN=
# IPs que nunca deben cuarentena/bloqueo automatico (CSV)
PROTECTED_IPS=
# API opcional de switches para cuarentena
SWITCH_API_URL=
# sAMAccountName de la cuenta de servicio NYXAR (nunca deshabilitar por playbook)
NYXAR_SERVICE_ACCOUNT_SAM=
AD_WRITE_ENABLED=false

# --- notifier (email + WhatsApp; sin Slack) ---
# Destinatarios CSV: emails con @, WhatsApp en E.164 (+54911...)
# URL base del dashboard (links "Ver en dashboard" en email y WhatsApp)
NOTIFY_DASHBOARD_BASE_URL=https://dashboard.tu-dominio.com
# Canales permitidos a nivel sistema (subset de email,whatsapp)
NOTIFY_CHANNELS_ENABLED=email,whatsapp
# Si está definida, PUT/POST de /api/v1/notifications/* mutables exigen header X-Notify-Api-Key
NOTIFY_API_KEY=
# Destinatarios solo para POST /api/v1/notifications/test (no usar cuentas reales de producción)
NOTIFY_TEST_EMAIL=
NOTIFY_TEST_WHATSAPP=
# IDs extra tratados como admin para reglas de preferencias (CSV). También se usan emails de NOTIFY_ADMIN_EMAILS.
NOTIFY_PREFERENCE_ADMIN_IDS=
# Responsable por área (email). Sustituir CONTABILIDAD por el nombre del área en MAYUS_SIN_ESPACIOS
# NOTIFY_AREA_CONTABILIDAD_EMAIL=conta@empresa.com

NOTIFY_ADMIN_EMAILS=
NOTIFY_ADMIN_WHATSAPP=
NOTIFY_SECURITY_EMAILS=
NOTIFY_SECURITY_WHATSAPP=
NOTIFY_REPORT_EMAILS=
NOTIFY_REPORT_WHATSAPP=
# Silencio nocturno (solo críticos y honeypot siguen notificando fuerte)
NOTIFY_QUIET_START=23:00
NOTIFY_QUIET_END=07:00
# SMTP opcional; si vacío, el email solo se registra en log
NOTIFY_SMTP_HOST=
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=
NOTIFY_SMTP_PASSWORD=
NOTIFY_SMTP_FROM=
NOTIFY_SMTP_TLS=true
# WhatsApp: API Cloud de Meta (https://developers.facebook.com/docs/whatsapp/cloud-api)
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_API_VERSION=v21.0
# Opcional: tu propio gateway HTTP si no usás Cloud API directo (POST JSON)
NOTIFY_WHATSAPP_HTTP_URL=
NOTIFY_WHATSAPP_HTTP_BEARER=
# Claves del JSON del gateway (por defecto to / message)
NOTIFY_WHATSAPP_HTTP_KEY_TO=to
NOTIFY_WHATSAPP_HTTP_KEY_MESSAGE=message
