# Copiar a .env.local y ajustar.
# Tras login, el dashboard envía Authorization: Bearer y WebSocket auth.token
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=http://localhost:8000
VITE_LAB_MODE=true
# true en .env.local = entrar al panel sin login (solo npm run dev; token placeholder)
# VITE_DEV_SKIP_LOGIN=true
# Opcional: health detallado en SystemHealth
# VITE_HEALTH_DETAIL_KEY=
